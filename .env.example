# Runtime mode used by the application.
NODE_ENV=development

# HTTP port exposed by the API.
PORT=3000

# PostgreSQL connection string used by the application.
# In Docker Compose, use the service name "postgres".
DATABASE_URL=postgres://postgres:postgres@postgres:5432/order_service

# Redis host used by the application.
# In Docker Compose, use the service name "redis".
REDIS_HOST=redis

# Redis port used by the application.
REDIS_PORT=6379

# Service name used in logs and OpenTelemetry traces.
OTEL_SERVICE_NAME=order-service

# OTLP HTTP endpoint used by the application.
# In Docker Compose, use the service name "otel-collector".
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Enables or disables trace export.
OTEL_TRACES_ENABLED=true

# Minimum application log level.
LOG_LEVEL=info